<Window x:Class="ClaudeNotifier.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Focusable="False"
        IsHitTestVisible="False"
        Width="440" Height="118">
    <Window.Resources>
        <Storyboard x:Key="EnterStoryboard">
            <DoubleAnimation Storyboard.TargetName="Root"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.25" />
            <DoubleAnimation Storyboard.TargetName="SlideTransform"
                             Storyboard.TargetProperty="Y"
                             From="40" To="0" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="ExitStoryboard" Completed="ExitStoryboard_Completed">
            <DoubleAnimation Storyboard.TargetName="Root"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.3" />
            <DoubleAnimation Storyboard.TargetName="SlideTransform"
                             Storyboard.TargetProperty="Y"
                             From="0" To="-40" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Grid x:Name="Root" Opacity="0">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="SlideTransform" Y="40" />
        </Grid.RenderTransform>
        <Border CornerRadius="14" Padding="18,14"
                BorderThickness="1.5"
                BorderBrush="#FFD68A1F"
                Background="#F01E1E22">
            <Border.Effect>
                <DropShadowEffect Color="#FFD68A1F" BlurRadius="28" ShadowDepth="0" Opacity="0.55" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Width="56" Height="56" CornerRadius="28" Margin="0,0,16,0"
                        Background="#FFD68A1F" VerticalAlignment="Center">
                    <TextBlock Text="!" Foreground="#FF1E1E22"
                               FontSize="34" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Claude needs approval"
                               Foreground="#FFFAFAFA" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock x:Name="MessageText" Margin="0,4,0,0"
                               Foreground="#FFCCCCCC" FontSize="13" TextWrapping="Wrap" />
                    <TextBlock x:Name="TabText" Margin="0,4,0,0"
                               Foreground="#FFD68A1F" FontSize="11" FontFamily="Consolas" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
