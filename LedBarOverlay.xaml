<Window x:Class="ClaudeNotifier.LedBarOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Focusable="False"
        Height="68">
    <Window.Resources>
        <LinearGradientBrush x:Key="BarBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FFE38B16" Offset="0.0" />
            <GradientStop Color="#FFFFB347" Offset="0.5" />
            <GradientStop Color="#FFE38B16" Offset="1.0" />
        </LinearGradientBrush>

        <Storyboard x:Key="EnterStoryboard">
            <!-- Bar grows -->
            <DoubleAnimation Storyboard.TargetName="Bar"
                             Storyboard.TargetProperty="Height"
                             From="0" To="6" Duration="0:0:0.22">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <!-- Bar sweep highlight -->
            <DoubleAnimation Storyboard.TargetName="Sweep"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="-400" To="2400" Duration="0:0:1.4"
                             RepeatBehavior="Forever" />
            <!-- Pulsing glow -->
            <DoubleAnimation Storyboard.TargetName="Glow"
                             Storyboard.TargetProperty="BlurRadius"
                             From="20" To="44" Duration="0:0:0.9"
                             AutoReverse="True" RepeatBehavior="Forever" />
            <!-- Card slides down from bar, fades in -->
            <DoubleAnimation Storyboard.TargetName="Card"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.35"
                             BeginTime="0:0:0.12" />
            <DoubleAnimation Storyboard.TargetName="CardSlide"
                             Storyboard.TargetProperty="Y"
                             From="-30" To="0" Duration="0:0:0.45"
                             BeginTime="0:0:0.12">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="ExitStoryboard" Completed="ExitStoryboard_Completed">
            <DoubleAnimation Storyboard.TargetName="Card"
                             Storyboard.TargetProperty="Opacity"
                             To="0" Duration="0:0:0.25" />
            <DoubleAnimation Storyboard.TargetName="CardSlide"
                             Storyboard.TargetProperty="Y"
                             To="-20" Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn" /></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Bar"
                             Storyboard.TargetProperty="Height"
                             To="0" Duration="0:0:0.28"
                             BeginTime="0:0:0.1" />
            <DoubleAnimation Storyboard.TargetName="Bar"
                             Storyboard.TargetProperty="Opacity"
                             To="0" Duration="0:0:0.28"
                             BeginTime="0:0:0.1" />
        </Storyboard>
    </Window.Resources>

    <Grid>
        <!-- Top LED bar -->
        <Border x:Name="Bar" Height="0" VerticalAlignment="Top" ClipToBounds="True"
                Background="{StaticResource BarBrush}">
            <Border.Effect>
                <DropShadowEffect x:Name="Glow" Color="#FFE38B16" BlurRadius="28" ShadowDepth="0" Opacity="1" />
            </Border.Effect>
            <Grid ClipToBounds="True">
                <!-- Moving highlight sweep -->
                <Rectangle x:Name="Sweep" Width="220" HorizontalAlignment="Left">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00FFFFFF" Offset="0" />
                            <GradientStop Color="#88FFFFFF" Offset="0.5" />
                            <GradientStop Color="#00FFFFFF" Offset="1" />
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                    <Rectangle.RenderTransform>
                        <TranslateTransform X="-400" />
                    </Rectangle.RenderTransform>
                </Rectangle>
            </Grid>
        </Border>

        <!-- Glass card centered below bar -->
        <Border x:Name="Card" VerticalAlignment="Top" Margin="0,14,0,0"
                HorizontalAlignment="Center"
                CornerRadius="20" Padding="20,10"
                Opacity="0"
                Background="#CC15161A"
                BorderBrush="#33FFB347" BorderThickness="1">
            <Border.RenderTransform>
                <TranslateTransform x:Name="CardSlide" Y="-30" />
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="28" ShadowDepth="6" Opacity="0.55" />
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <Border Width="10" Height="10" CornerRadius="5" Background="#FFE38B16"
                        Margin="0,0,12,0" VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect Color="#FFE38B16" BlurRadius="14" ShadowDepth="0" />
                    </Border.Effect>
                </Border>
                <StackPanel>
                    <TextBlock x:Name="EyebrowText" Text="CLAUDE   ·   AWAITING APPROVAL"
                               Foreground="#FFE38B16" FontSize="11" FontWeight="SemiBold"
                               FontFamily="Segoe UI" />
                    <TextBlock x:Name="MessageText" Margin="0,2,0,0"
                               Foreground="#FFEFEFEF" FontSize="14" FontWeight="Medium" />
                    <TextBlock x:Name="TabText" Margin="0,2,0,0"
                               Foreground="#FF9A9AA0" FontSize="10" FontFamily="Cascadia Mono, Consolas" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
